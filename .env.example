# Copy this file to .env for local dev (never commit .env)
# On Vercel: Project → Settings → Environment Variables

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
# Free tier at https://mongodb.com/atlas
# Format: mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=pinay_cupid

# ── Cloudinary ────────────────────────────────────────────────────────────────
# Free tier at https://cloudinary.com  (25 GB storage, 25 GB bandwidth/month)
# All three values are on your Cloudinary Dashboard home page
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── App security ──────────────────────────────────────────────────────────────
# JWT + flash cookie signing — any long random string
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-string
