# Copy this file to .env for local dev (never commit .env)
# On Vercel: Project → Settings → Environment Variables

# MongoDB Atlas connection string (free tier at https://mongodb.com/atlas)
# Format: mongodb+srv://user:password@cluster.mongodb.net/pinay_cupid?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority

# Optional: override the database name (default: pinay_cupid)
MONGODB_DB=pinay_cupid

# JWT + flash cookie signing key — any long random string
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-string
